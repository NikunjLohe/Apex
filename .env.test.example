# APEX Playwright Test Environment
# Copy this to .env.test and fill in your values.
# NEVER commit .env.test to version control.

# ── Application URL ──────────────────────────────────────────────────────────
# Use localhost for local dev; swap for Vercel URL for staging tests.
TEST_BASE_URL=http://localhost:5173
# TEST_BASE_URL=https://apex-branch-ops.vercel.app

# ── Test Accounts ────────────────────────────────────────────────────────────
# These accounts must exist in your Firebase project.
# Super Admin
SUPER_ADMIN_EMAIL=superadmin@apex.test
SUPER_ADMIN_PASSWORD=TestPass@2024!

# Admin (Rank 14)
ADMIN_EMAIL=admin@apex.test
ADMIN_PASSWORD=TestPass@2024!

# Branch Manager (Rank 10)
MANAGER_EMAIL=manager@apex.test
MANAGER_PASSWORD=TestPass@2024!

# Field Agent (Rank 1)
AGENT_EMAIL=agent@apex.test
AGENT_PASSWORD=TestPass@2024!

# ── Test Data Seed IDs ───────────────────────────────────────────────────────
# Pre-seeded IDs in your Firestore test environment.
TEST_BRANCH_ID=
TEST_AGENT_SPONSOR_CODE=AG000001
TEST_CUSTOMER_ACCOUNT=CUS000001
TEST_POLICY_NUMBER=RD-000001

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function meExists() { return exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function myRank() { return (signedIn() && meExists()) ? ('rank' in me() ? (me().rank is string ? int(me().rank) : me().rank) : 0) : 0; }
    function isSuper() { return (signedIn() && meExists()) && ('isSuperAdmin' in me() && me().isSuperAdmin == true); }
    function isAdmin() { return isSuper() || myRank() >= 14; }
    function isStaff() { return (signedIn() && meExists()) && (isAdmin() || myRank() >= 1); }

    // System summaries: staff read, staff write (agents need to update stats on payment collection)
    match /system_summaries/{doc} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    // Users: self read; admins read all; admins write.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isAdmin();
      // allow a member to update limited self fields (not rank/role/super/etc)
      allow update: if request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rank', 'isSuperAdmin', 'isAdmin', 'role', 'permissions', 'sponsorCode', 'sponsorId', 'branchId', 'branchAssignment', 'status', 'commissionConfig', 'promotionConfig', 'rewardConfig']);
    }

    // Branches: staff read; admins write.
    match /branches/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Customers / plans / payments / receipts
    match /customers/{id} { 
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && (isAdmin() || resource.data.enrolledBy == request.auth.uid);
    }
    match /plans/{id} { 
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && (isAdmin() || resource.data.agentId == request.auth.uid);
    }
    match /payments/{id} { 
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && (isAdmin() || resource.data.agentId == request.auth.uid);
    }
    match /receipts/{id} { 
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && (isAdmin() || resource.data.generatedBy == request.auth.uid);
    }
    match /notifications/{id} { 
      allow read, write: if isStaff(); 
    }
    match /plans_master/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /imports/{id}      { allow read, write: if isAdmin(); }
    match /policies/{id}     { allow read, write: if isStaff(); }
    match /promotions/{id}   { allow read: if isStaff(); allow write: if isAdmin(); }
    match /promotion_recommendations/{id} { allow read: if isStaff(); allow write: if isAdmin(); }

    // Atomic counters for account/receipt numbers.
    match /counters/{name} { allow read, write: if isStaff(); }

    // Commission and Payout data
    match /commissions/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /commission_ledger/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /payouts/{id} { allow read: if isStaff(); allow write: if isAdmin(); }


    // App config (settings) — staff read, admin write.
    match /config/{doc} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
  }
}

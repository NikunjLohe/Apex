rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function meExists() { return exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function myRank() { return (signedIn() && meExists()) ? (me().rank is string ? int(me().rank) : me().rank) : 0; }
    function isSuper() { return (signedIn() && meExists()) && me().isSuperAdmin == true; }
    function isAdmin() { return isSuper() || myRank() >= 14; }
    function isStaff() { return (signedIn() && meExists()) && (isAdmin() || myRank() >= 1); }

    // System summaries: staff read, admin write
    match /system_summaries/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Users: self read; admins read all; admins write.
    match /users/{uid} {
      allow read, write: if true;
      // allow a member to update limited self fields (not rank/role/super)
      allow update: if request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAll(['rank'])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAll(['isSuperAdmin'])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAll(['status'])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAll(['branchId']);
    }

    // Branches: staff read; admins write.
    match /branches/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Customers / plans / payments / receipts: any staff may read & write
    // (branch employees onboard and collect). Tighten with branch checks later.
    match /customers/{id} { allow read, write: if isStaff(); }
    match /plans/{id}     { allow read, write: if isStaff(); }
    match /payments/{id}  { allow read, write: if isStaff(); }
    match /receipts/{id}  { allow read, write: if isStaff(); }
    match /notifications/{id} { allow read, write: if isStaff(); }
    match /plans_master/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /imports/{id}      { allow read, write: if isAdmin(); }
    match /policies/{id}     { allow read, write: if isStaff(); }
    match /promotions/{id}   { allow read: if isStaff(); allow write: if isAdmin(); }

    // Atomic counters for account/receipt numbers.
    match /counters/{name} { allow read, write: if isStaff(); }

    // Commission and Payout data
    match /commissions/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /payouts/{id} { allow read: if isStaff(); allow write: if isAdmin(); }


    // App config (settings) — staff read, admin write.
    match /config/{doc} {
      allow read, write: if true;
    }
  }
}
